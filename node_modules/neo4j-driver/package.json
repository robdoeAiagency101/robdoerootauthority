{
  "name": "neo4j-driver",
  "version": "6.2.0",
  "description": "The official Neo4j driver for Javascript",
  "author": "Neo4j",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/neo4j/neo4j-javascript-driver.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "ts-standard": {
    "ignore": [
      "test/*.ts",
      "*.ts"
    ]
  },
  "scripts": {
    "lint": "eslint --fix --ext .js ./",
    "test": "gulp test",
    "test::unit": "gulp test-nodejs-unit && gulp run-ts-declaration-tests",
    "test::browser": "gulp test-browser",
    "test::integration": "gulp test-nodejs-integration",
    "test::stress": "gulp run-stress-tests",
    "build": "gulp all",
    "start-neo4j": "gulp start-neo4j",
    "stop-neo4j": "gulp stop-neo4j",
    "run-stress-tests": "gulp run-stress-tests",
    "run-ts-declaration-tests": "gulp run-ts-declaration-tests",
    "docs": "esdoc -c esdoc.json",
    "versionRelease": "gulp set --x $VERSION",
    "browser": "gulp browser && gulp test-browser",
    "prepare": "pnpm run build",
    "clean": "rm -fr node_modules lib build"
  },
  "main": "lib/index.js",
  "browser": {
    "./lib/internal/node/index.js": "./lib/internal/browser/index.js"
  },
  "unpkg": "lib/browser/neo4j-web.js",
  "jsdelivr": "lib/browser/neo4j-web.js",
  "types": "types/index.d.ts",
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-transform-runtime": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@babel/register": "7.28.6",
    "@babel/runtime": "7.29.2",
    "@rollup/plugin-commonjs": "^21.1.0",
    "@rollup/plugin-node-resolve": "^13.3.0",
    "@sinonjs/fake-timers": "15.3.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.12.2",
    "@types/vinyl": "^2.0.12",
    "async": "3.2.6",
    "browser-resolve": "2.0.0",
    "esdoc": "1.1.0",
    "esdoc-importpath-plugin": "1.0.2",
    "esdoc-standard-plugin": "1.0.0",
    "fancy-log": "2.0.0",
    "gulp": "4.0.2",
    "gulp-batch": "1.0.5",
    "gulp-decompress": "3.0.0",
    "gulp-replace": "1.1.4",
    "gulp-typescript": "5.0.1",
    "gulp-uglify": "3.0.2",
    "gulp-watch": "5.0.1",
    "isomorphic-ws": "4.0.1",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "minimist": "1.2.8",
    "rollup": "2.80.0",
    "rollup-plugin-polyfill-node": "0.13.0",
    "semver": "7.7.4",
    "source-map": "0.7.4",
    "testcontainers": "8.16.0",
    "tmp": "0.2.1",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vinyl-buffer": "1.0.1",
    "webpack": "5.106.2",
    "ws": "8.20.0"
  },
  "dependencies": {
    "neo4j-driver-bolt-connection": "6.2.0",
    "neo4j-driver-core": "6.2.0",
    "rxjs": "^7.8.2"
  },
  "gitHead": "493b9ef5fc0884f4e5cad5bdc23fd36631cbf5e3"
}
